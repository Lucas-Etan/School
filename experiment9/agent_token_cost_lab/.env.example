# 本地 Ollama 示例。LLM_MODEL 必须改成 ollama list 中实际存在的模型名。
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_API_KEY=local
LLM_MODEL=<OLLAMA_MODEL_NAME>
LLM_MAX_OUTPUT_TOKENS=96
LLM_TIMEOUT_SECONDS=60
LLM_PRICE_INPUT_PER_1K=0
LLM_PRICE_OUTPUT_PER_1K=0

# 如果使用在线 OpenAI-compatible API，可改成供应商给出的 /v1 地址。
# LLM_BASE_URL=https://<PROVIDER_BASE_URL>/v1
# LLM_API_KEY=<YOUR_API_KEY>
# LLM_MODEL=<SMALL_MODEL_NAME>
# LLM_PRICE_INPUT_PER_1K=<INPUT_PRICE>
# LLM_PRICE_OUTPUT_PER_1K=<OUTPUT_PRICE>